{
  "name": "meetingbot",
  "version": "1.0.1",
  "private": true,
  "description": "Discord議事録Bot - 録音→文字起こし→Claude要約→Notion議事録",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "discord",
    "bot",
    "meeting",
    "transcription"
  ],
  "author": "hoshiorange",
  "license": "MIT",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@notionhq/client": "^5.20.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "googleapis": "^171.4.0",
    "opusscript": "^0.0.8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "prism-media": "^1.3.5",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
