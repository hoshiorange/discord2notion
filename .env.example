# 議事録Bot 環境変数テンプレート
# このファイルをコピーして `.env` を作成し、各値を埋めてください。
# `.env` は gitignore されています。

# ============================================================
# Discord
# ============================================================

# Discord Developer Portal で Bot 作成後に発行されるトークン
# https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# （任意）Bot を招待した Discord サーバーの ID。設定するとスラッシュコマンドが
# その Guild 限定で即時反映される（未設定だとグローバル登録、最大1時間反映）
# Discord で開発者モード ON → サーバー右クリック → ID コピー
DISCORD_GUILD_ID=

# ============================================================
# Notion
# ============================================================

# Notion Internal Integration の Token
# https://www.notion.so/profile/integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 議事録 DB の ID（DB の URL `notion.so/<ID>?v=...` の <ID> 部分、ハイフンなしでもOK）
# Integration をこの DB に招待しておくこと
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Google Drive
# ============================================================

# OAuth Desktop クライアントの credentials.json へのパス
# GCP Console で作成 → JSON ダウンロード → プロジェクトに配置
# 相対パス可（プロジェクトルート起点）、絶対パスも可
GOOGLE_DRIVE_CREDENTIALS=credentials.json

# OAuth リフレッシュトークン
# `npx tsx scripts/test_drive.py` 等で OAuth 認可フローを実行して取得
# scripts/test_drive.py は実行時に自動で .env に書き込む
GOOGLE_DRIVE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# 任意（チューニング用）
# ============================================================

# 録音時間の上限（分）。これを超えたら自動停止+変換パイプライン実行
# 既定: 480（8時間）
# RECORDING_MAX_MINUTES=480

# Whisper 文字起こしのタイムアウト（ミリ秒）
# 既定: 600000（10分）。1時間音声でも数分で完了するため通常は変更不要
# TRANSCRIBE_TIMEOUT_MS=600000

# Claude Code 要約のタイムアウト（ミリ秒）
# 既定: 600000（10分）
# SUMMARIZE_TIMEOUT_MS=600000

# Python 実行ファイルのパス（Whisper CLI 呼び出し用）
# 既定: .venv/Scripts/python.exe（存在すれば）→ なければ python（PATH）
# PYTHON_BIN=

# Claude CLI のパス
# 既定: claude（PATH 解決）。Windows なら通常 C:\Users\<you>\.local\bin\claude.exe
# CLAUDE_BIN=

# ============================================================
# ログ (AIP-34)
# ============================================================

# ログ出力ディレクトリ（プロジェクトルート起点の相対パス、または絶対パス）
# 既定: logs
# LOG_DIR=logs

# ログレベル: trace / debug / info / warn / error / fatal / silent
# 既定: info
# LOG_LEVEL=info

# 古いログファイルを保持する日数。これより古い `<LOG_DIR>/*.log` は
# 起動時 + 24h 間隔で自動削除される。
# 既定: 14
# LOG_RETAIN_DAYS=14

# 本番モード切替: 'production' を指定すると pino-pretty が無効化されて
# JSON 形式のファイル出力のみになる（pm2 / systemd で動かす時用）
# 既定: 未設定（=開発モード = stdout に整形 + ファイル両方）
# NODE_ENV=production
