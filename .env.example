# 議事録Bot 環境変数テンプレート
# このファイルをコピーして `.env` を作成し、各値を埋めてください。
# `.env` は gitignore されています。
#
# ============================================================
# マルチ Guild 設定について（任意）
# ============================================================
# 1 つの Bot プロセスを複数 Discord サーバ（Guild）に招待し、
# Guild ごとに別の Notion DB / 別の Google アカウントへ振り分けたい場合のみ
# 以下を設定してください（単一 Guild 運用なら不要、`.env` 一本で動作）。
#
# 配置: config/guilds/<guildId>.json
# 例:   config/guilds/1234567890123456789.json
# {
#   "name": "仕事",
#   "notionApiKey": "ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
#   "notionDatabaseId": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
#   "googleDriveCredentials": "credentials.guild-1234567890123456789.json",
#   "googleDriveRefreshToken": "1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# }
#
# 書いたキーだけ Guild 側で上書きされ、書かないキーは下記 .env から引き継ぎます。
# 詳細は docs/MULTI_GUILD.md を参照。
# `config/` と `credentials.guild-*.json` は gitignore 済みです。

# ============================================================
# Discord  ★ DISCORD_TOKEN は唯一の必須環境変数（Bot 起動時にチェック）
# ============================================================

# Discord Developer Portal で Bot 作成後に発行されるトークン
# https://discord.com/developers/applications
# ※ Bot 共通の値。Guild 別の上書きは不可（マルチ Guild でも同じトークンを使う）
DISCORD_TOKEN=your_discord_bot_token_here

# （任意）Bot を招待した Discord サーバーの ID。設定するとスラッシュコマンドが
# その Guild 限定で即時反映される（未設定だとグローバル登録、最大1時間反映）
# Discord で開発者モード ON → サーバー右クリック → ID コピー
DISCORD_GUILD_ID=

# ============================================================
# Notion  ★ 起動時必須ではない（config/guilds/<guildId>.json に書いた場合は .env に書かなくてよい）
# ============================================================
# 単一 Guild 運用 or デフォルト出力先を持たせたい場合は下記に値を入れる。
# マルチ Guild 運用で全 Guild 別 JSON にした場合は空のままで OK（起動は通る）。
# 該当キーが .env にも Guild JSON にも無い Guild から /start すると、Notion ステージで失敗する。

# Notion Internal Integration の Token
# https://www.notion.so/profile/integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 議事録 DB の ID（DB の URL `notion.so/<ID>?v=...` の <ID> 部分、ハイフンなしでもOK）
# Integration をこの DB に招待しておくこと
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Google Drive  ★ 起動時必須ではない（Notion と同じく Guild 別 JSON に書いてもよい）
# ============================================================

# OAuth Desktop クライアントの credentials.json へのパス
# GCP Console で作成 → JSON ダウンロード → プロジェクトに配置
# 相対パス可（プロジェクトルート起点）、絶対パスも可
GOOGLE_DRIVE_CREDENTIALS=credentials.json

# OAuth リフレッシュトークン
# `npx tsx scripts/test_drive.py` 等で OAuth 認可フローを実行して取得
# scripts/test_drive.py は実行時に自動で .env に書き込む
GOOGLE_DRIVE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# 任意（チューニング用）
# ============================================================

# 録音時間の上限（分）。これを超えたら自動停止+変換パイプライン実行
# 既定: 480（8時間）
# RECORDING_MAX_MINUTES=480

# 完了済みセッション（recordings/<sessionId>/）の保持日数。これより古いものは
# 起動時 + 24h 周期で `cleanupOldSessions` が自動削除する。
# 既定: 30
# RECORDINGS_RETAIN_DAYS=30

# Voice 切断時の手動 rejoin 試行回数（Phase 2）
# 既定: 3
# VOICE_RECONNECT_MAX_ATTEMPTS=3

# rejoin の線形バックオフ初期値（ミリ秒）。試行 N 回目で N * BACKOFF_MS 待つ。
# 既定: 2000
# VOICE_RECONNECT_BACKOFF_MS=2000

# Whisper 文字起こしのタイムアウト（ミリ秒）
# 既定: 600000（10分）。1時間音声でも数分で完了するため通常は変更不要
# TRANSCRIBE_TIMEOUT_MS=600000

# Claude Code 要約のタイムアウト（ミリ秒）
# 既定: 600000（10分）
# SUMMARIZE_TIMEOUT_MS=600000

# Python 実行ファイルのパス（Whisper CLI 呼び出し用）
# 既定: .venv/Scripts/python.exe（存在すれば）→ なければ python（PATH）
# PYTHON_BIN=

# Claude CLI のパス
# 既定: claude（PATH 解決）。Windows なら通常 C:\Users\<you>\.local\bin\claude.exe
# CLAUDE_BIN=

# ============================================================
# ログ
# ============================================================

# ログ出力ディレクトリ（プロジェクトルート起点の相対パス、または絶対パス）
# 既定: logs
# LOG_DIR=logs

# ログレベル: trace / debug / info / warn / error / fatal / silent
# 既定: info
# LOG_LEVEL=info

# 古いログファイルを保持する日数。これより古い `<LOG_DIR>/*.log` は
# 起動時 + 24h 間隔で自動削除される。
# 既定: 14
# LOG_RETAIN_DAYS=14

# 本番モード切替: 'production' を指定すると pino-pretty が無効化されて
# JSON 形式のファイル出力のみになる（pm2 / systemd で動かす時用）
# 既定: 未設定（=開発モード = stdout に整形 + ファイル両方）
# NODE_ENV=production
